@model dynamic

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Email Verification</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
  </style>
</head>

<body
  style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6; padding: 40px 20px;">
  <div
    style="max-width: 600px; margin: 0 auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);">
    <!-- Banner with Email Icon -->
    <div
      style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 50px 30px; text-align: center; position: relative;">
      <div style="width: 100px;
      height: 100px;
      background: white;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);">
        <img src="https://res.cloudinary.com/dlecit4kf/image/upload/q_auto/f_auto/v1775125842/favicon_rjw4xu.png"
          style="width: 100%;; color: #667eea;" alt="Logo">
      </div>
    </div>

    <!-- Email Body -->
    <div style="padding: 40px 30px;">
      <h1 style="font-size: 28px;
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 20px;">Email Verification</h1>

      <p style="font-size: 16px;
      line-height: 1.8;
      color: #64748b;
      margin-bottom: 30px;">
        Hi <strong style="color: #1e293b;
      font-weight: 600;">@Model.Username</strong>,
      </p>

      <p style="font-size: 16px;
      line-height: 1.8;
      color: #64748b;
      margin-bottom: 30px;">
        You're almost set to start enjoying <strong style="color: #1e293b;
      font-weight: 600;">Étudify</strong>. Simply click the button below to verify
        your email address and get started. The link expires in <strong>15 minutes</strong>.
      </p>

      <div style="text-align: center; margin: 30px 0;">
        <a href="@Model.Link" style="display: inline-block;
      padding: 16px 40px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      text-decoration: none;
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
      transition: all 0.3s;">
          VERIFY EMAIL
        </a>
      </div>

      <div style="height: 1px;
      background: linear-gradient(to right, transparent, #e5e7eb, transparent);
      margin: 30px 0;"></div>

      <p style="font-size: 16px;
      line-height: 1.8;
      color: #64748b;
      margin-bottom: 30px; font-size: 14px; color: #94a3b8;">
        If you did not create an account with us, you can safely ignore this email.
      </p>
    </div>

    <!-- Footer -->
    <div style="padding: 30px;
      background: #fafafa;
      text-align: center;">
      <!-- Social Media Links -->
      <div style="margin-bottom: 20px;">
        <a href="https://www.facebook.com/buihien.tiensi.58/" target="_blank" style="display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      margin: 0 8px;
      text-decoration: none;
      transition: all 0.3s;
      color: white;
      font-size: 20px;
      background: #1877f2;">
          <img
            src="https://static.vecteezy.com/system/resources/previews/018/930/476/non_2x/facebook-logo-facebook-icon-transparent-free-png.png"
            alt="" style="width: 100%;">
        </a>
        <a href="https://www.tiktok.com/@@ngtrh_hgbaov" target="_blank" style="display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      margin: 0 8px;
      text-decoration: none;
      transition: all 0.3s;
      color: white;
      font-size: 20px;
      background: #000000;">
          <img src="https://static.vecteezy.com/system/resources/thumbnails/016/716/450/small/tiktok-icon-free-png.png"
            alt="" style="width: 100%;">
        </a>
        <a href="https://www.instagram.com/its.trneih/" target="_blank" style="display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      margin: 0 8px;
      text-decoration: none;
      transition: all 0.3s;
      color: white;
      font-size: 20px;
      background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);">
          <img
            src="https://static.vecteezy.com/system/resources/thumbnails/065/386/516/small/instagram-circle-logo-icon-ig-app-transparent-background-premium-social-media-design-for-digital-download-free-png.png"
            alt="" width="100%">
        </a>
      </div>

      <!-- Footer Text -->
      <p style="font-size: 14px;
      color: #94a3b8;
      margin-bottom: 10px;">
        18 Hoang Quoc Viet, Ha Noi, Viet Nam
      </p>
    </div>
  </div>
</body>

</html>